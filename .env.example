DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver

# Optional: use conda to run the bridge in a dedicated env.
PPTMAKER_CONDA=
PPTMAKER_BRIDGE_JSON_TIMEOUT=7200

# LLM providers
GOOGLE_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_VISION_MODEL=
PPTMAKER_SMART_LLM_MODE=auto

# MinerU / figure extraction
MINERU_BIN=
PPTMAKER_MINERU_BACKEND=pipeline
PPTMAKER_MINERU_TIMEOUT_SECONDS=1800
PPTMAKER_FIGURE_BACKEND=auto
